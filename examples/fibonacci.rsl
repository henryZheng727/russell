fn fibonacci(x: Int) -> Int {
    return if x == 0 then
        0
    else if x == 1 then
        1
    else
        fibonacci(x - 1) + fibonacci(x - 2);
}

fn main() -> Int {
    echo Int fibonacci(0);
    echo Int fibonacci(1);
    echo Int fibonacci(10);
    echo Int fibonacci(20);
    echo Int fibonacci(100);
    return 0;
}
