// custom boolean type
typedef CustomBool {
    c_true(),
    c_false()
}

// into a normal bool
fn convert_to_normal(x: CustomBool) -> Bool {
    return match x {
        c_true() -> true,
        c_false() -> false
    };
}

fn custom_if_i64(cond: CustomBool, then_b: Int, else_b: Int) -> Int {
    return match cond {
        c_true() -> then_b,
        c_false() -> false_b
    };
}

fn custom_if_f64(cond: CustomBool, then_b: Float, else_b: Float) -> Float {
    return match cond {
        c_true() -> then_b,
        c_false() -> false_b
    };
}

// main function to test everything
fn main() -> Int {
    echo Bool convert_to_normal(c_true());
    echo Bool convert_to_normal(c_false());

    echo Int custom_if_i64(c_true(), 0, 1);
    echo Int custom_if_i64(c_false(), 0, 1);

    echo Float custom_if_f64(c_true(), 0, 1);
    echo Float custom_if_f64(c_false(), 0, 1);

    return 0;
}
